rub1 = int(input("рубли для первого товара: "))
kop1 = int(input("копейки для первого товара: "))
rub2 = int(input("рубли для второго товара: "))
kop2 = int(input("копейки для второго товара: "))
cost1 = rub1 * 100 + kop1
cost2 = rub2 * 100 + kop2
if cost1 > cost2:
    print("первый товар дороже")
elif cost1 < cost2:
    print("второй товар дороже")
else:
    print("оба товара стоят одинаково")
